---
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
}
const { locale = 'et' } = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer>
  <!-- Decorative top border -->
  <div class="flex items-center justify-center gap-3 py-6">
    <div class="h-[1px] w-20 bg-gradient-to-r from-transparent to-gold/40"></div>
    <span class="text-gold/50 text-[10px]">&#9830;</span>
    <div class="h-[1px] w-20 bg-gradient-to-l from-transparent to-gold/40"></div>
  </div>

  <div class="bg-warm-dark text-warm-white/90">
    <div class="max-w-6xl mx-auto px-6 pt-14 pb-10">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12">

        <!-- Brand + contact -->
        <div class="md:col-span-4">
          <h3 class="font-display text-2xl text-warm-white mb-6">{t(locale, 'footer.brand')}</h3>

          <ul class="space-y-1 font-body text-sm text-warm-white/75">
            <li>
              <a href="tel:+37254210881" class="inline-flex items-center min-h-[44px] hover:text-gold-light transition-colors">
                +372 5421 0881
              </a>
            </li>
            <li>
              <a href="mailto:info@laitsecastle.ee" class="inline-flex items-center min-h-[44px] hover:text-gold-light transition-colors">
                info@laitsecastle.ee
              </a>
            </li>
            <li class="pt-1 text-warm-white/50">
              {t(locale, 'footer.address')}
            </li>
          </ul>
        </div>

        <!-- Map -->
        <div class="md:col-span-8">
          <div class="w-full rounded-lg overflow-hidden shadow-lg">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2399.652899443389!2d24.38460711302241!3d59.19656527444412!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4692b74ee626aadd%3A0x2f7cebea9b79a006!2sLaitse%20loss%2C%20Laitse%2C%2076302%20Harju%20maakond%2C%20Estonia!5e1!3m2!1sen!2sus!4v1773305950212!5m2!1sen!2sus"
              width="100%"
              height="220"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={t(locale, 'footer.mapTitle')}
              class="h-[200px] md:h-[260px] w-full"
            ></iframe>
          </div>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="mt-12 pt-6 border-t border-warm-white/10 flex flex-wrap items-center justify-between gap-4">
        <p class="font-ui text-xs text-warm-white/40">
          &copy; {currentYear} Nevaliste O&Uuml;
        </p>
      </div>
    </div>
  </div>
</footer>
