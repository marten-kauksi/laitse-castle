---
const currentYear = new Date().getFullYear();
---

<footer>
  <!-- Gold accent line at top -->
  <div class="bg-gold-gradient-h h-[1px]"></div>

  <div class="bg-burgundy text-warm-white">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- Contact info -->
        <div>
          <h3 class="font-display text-xl mb-4">Laitse Loss</h3>
          <ul class="space-y-2 font-ui text-sm text-warm-white/85">
            <li>
              <a href="tel:+37258356509" class="hover:text-gold-light transition-colors">
                +372 58 356 509
              </a>
            </li>
            <li>
              <a href="mailto:info@laitseloss.ee" class="hover:text-gold-light transition-colors">
                info@laitseloss.ee
              </a>
            </li>
            <li>
              Lossi tee 9, 76302 Laitse, Harjumaa
            </li>
          </ul>
        </div>

        <!-- Google Maps placeholder -->
        <div>
          <div class="w-full h-[250px] bg-burgundy-hover rounded flex items-center justify-center text-warm-white/50 font-ui text-sm border border-warm-white/10">
            <div class="text-center">
              <svg class="w-8 h-8 mx-auto mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <span>Google Maps</span>
            </div>
          </div>
        </div>

        <!-- Company info -->
        <div class="flex flex-col justify-between">
          <div>
            <p class="font-ui text-sm text-warm-white/85">
              &copy; {currentYear} Laitse Loss O&Uuml;
            </p>
          </div>
          <div class="mt-4">
            <a href="#" class="font-ui text-sm text-warm-white/60 hover:text-gold-light transition-colors underline underline-offset-4">
              Privaatsuspoliitika
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
