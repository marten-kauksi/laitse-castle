---
import { t, getLocalizedPath } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale?: Locale;
}
const { locale = 'et' } = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { label: t(locale, 'nav.home'), href: getLocalizedPath('/', locale) },
  { label: t(locale, 'nav.events'), href: getLocalizedPath('/peod', locale) },
  { label: t(locale, 'nav.seminars'), href: getLocalizedPath('/seminarid', locale) },
  {
    label: t(locale, 'nav.addons'),
    href: getLocalizedPath('/lisateenused', locale),
    children: [
      { label: t(locale, 'nav.addon.murder'), href: getLocalizedPath('/lisateenused/morvamysteerium', locale) },
      { label: t(locale, 'nav.addon.chocolate'), href: getLocalizedPath('/lisateenused/sokolaadikoolitus', locale) },
    ],
  },
  { label: t(locale, 'nav.gallery'), href: getLocalizedPath('/galerii', locale) },
  { label: t(locale, 'nav.history'), href: getLocalizedPath('/ajalugu', locale) },
];
---

<header class="fixed top-0 left-0 right-0 z-50 header-transparent transition-all duration-500" id="site-header">
  <div class="announcement-banner bg-green-700 text-warm-white text-center px-4 py-2 font-body text-[12px] leading-relaxed" id="announcement-banner">
    <p class="max-w-[800px] mx-auto"><Fragment set:html={t(locale, 'header.announcement')} /></p>
  </div>
  <nav class="pl-0 pr-4 py-1 md:pr-6 md:py-1 flex items-center justify-between max-w-7xl mx-auto">
    <a href="/" class="shrink-0">
      <img src="/images/laitse-castle-logo.webp" alt="Laitse loss" class="h-[32px] md:h-[44px] w-auto transition-all duration-500" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-5 xl:gap-7">
      {navLinks.map(({ label, href, children }) => (
        <li class="relative group">
          <a
            href={href}
            class:list={[
              'nav-link font-ui uppercase tracking-wide text-sm transition-colors duration-300',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-burgundy'
                : '',
            ]}
          >
            {label}
          </a>
          {children && children.length > 0 && (
            <ul class="absolute left-1/2 -translate-x-1/2 top-full pt-4 hidden group-hover:block group-focus-within:block">
              <div class="bg-warm-white border border-black/10 rounded shadow-lg py-2 min-w-[240px]">
                {children.map((c) => (
                  <li>
                    <a
                      href={c.href}
                      class:list={[
                        'block px-5 py-2.5 font-ui uppercase tracking-wide text-[13px] transition-colors duration-200',
                        currentPath === c.href ? 'text-burgundy' : 'text-warm-dark hover:text-burgundy hover:bg-black/5',
                      ]}
                    >
                      {c.label}
                    </a>
                  </li>
                ))}
              </div>
            </ul>
          )}
        </li>
      ))}
    </ul>
    <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />

    <!-- Mobile hamburger -->
    <details class="lg:hidden relative" id="mobile-nav">
      <summary class="list-none cursor-pointer p-3 -mr-3 min-w-[44px] min-h-[44px] flex items-center justify-center">
        <span class="sr-only">{t(locale, 'header.menu')}</span>
        <svg class="hamburger-icon w-6 h-6 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <ul class="absolute right-0 top-full mt-2 bg-warm-white border border-black/10 rounded shadow-lg py-2 min-w-[220px]">
        {navLinks.map(({ label, href, children }) => (
          <li>
            <a
              href={href}
              class:list={[
                'block px-5 py-3 font-ui uppercase tracking-wide text-sm transition-colors duration-200 min-h-[44px] flex items-center',
                currentPath === href || (href !== '/' && currentPath.startsWith(href))
                  ? 'text-burgundy'
                  : 'text-warm-dark hover:text-burgundy hover:bg-black/5',
              ]}
            >
              {label}
            </a>
            {children && children.length > 0 && (
              <ul>
                {children.map((c) => (
                  <li>
                    <a
                      href={c.href}
                      class:list={[
                        'block pl-9 pr-5 py-2.5 font-ui uppercase tracking-wide text-[12px] transition-colors duration-200 flex items-center',
                        currentPath === c.href ? 'text-burgundy' : 'text-stone hover:text-burgundy hover:bg-black/5',
                      ]}
                    >
                      {c.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <li class="px-5 py-3">
          <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
        </li>
      </ul>
    </details>
  </nav>
  <div class="header-rule h-[1px] w-full transition-opacity duration-500"></div>
</header>

<!-- Spacer to prevent content jump (header is fixed) -->
<div class="h-0" id="header-spacer"></div>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  /* Transparent state — over hero */
  .header-transparent {
    background: rgba(44, 40, 36, 0.25);
  }
  .header-transparent .nav-link.text-burgundy {
    color: #FAF7F2;
  }
  .header-transparent .nav-link:not(.text-burgundy),
  .header-transparent .lang-link {
    color: rgba(250, 247, 242, 0.65);
  }
  .header-transparent .nav-link:not(.text-burgundy):hover,
  .header-transparent .lang-link:hover {
    color: #FAF7F2;
  }
  .header-transparent .hamburger-icon {
    color: rgba(250, 247, 242, 0.9);
  }
  .header-transparent .announcement-banner {
    max-height: 120px;
    opacity: 1;
    overflow: hidden;
    transition: max-height 0.5s ease, opacity 0.3s ease;
  }
  .header-transparent .header-rule {
    background: linear-gradient(90deg, transparent, rgba(196, 164, 105, 0.3), transparent);
    opacity: 0;
  }

  /* Solid state — after scrolling past hero */
  .header-solid {
    background: rgba(250, 247, 242, 0.95);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
  }
  .header-solid .nav-link:not(.text-burgundy),
  .header-solid .lang-link {
    color: #2C2824;
  }
  .header-solid .nav-link:not(.text-burgundy):hover,
  .header-solid .lang-link:hover {
    color: #722F37;
  }
  .header-solid .hamburger-icon {
    color: #2C2824;
  }
  .header-solid .announcement-banner {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    padding-top: 0;
    padding-bottom: 0;
    transition: max-height 0.4s ease, opacity 0.2s ease, padding 0.4s ease;
  }
  .header-solid .header-rule {
    background: linear-gradient(90deg, transparent, rgba(196, 164, 105, 0.4), transparent);
    opacity: 1;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const spacer = document.getElementById('header-spacer');

  if (header) {
    // Find the first section (hero) to know when to switch
    const hero = document.querySelector('main > section:first-child');
    const triggerPoint = hero ? hero.getBoundingClientRect().height * 0.15 : 80;

    let isTransparent = true;

    function updateHeader() {
      const scrollY = window.scrollY;
      if (scrollY > triggerPoint && isTransparent) {
        header!.classList.remove('header-transparent');
        header!.classList.add('header-solid');
        isTransparent = false;
      } else if (scrollY <= triggerPoint && !isTransparent) {
        header!.classList.remove('header-solid');
        header!.classList.add('header-transparent');
        isTransparent = true;
      }
    }

    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();
  }

  // Close mobile nav when a link is clicked
  const nav = document.getElementById('mobile-nav');
  if (nav) {
    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        (nav as HTMLDetailsElement).open = false;
      });
    });
  }
</script>
