---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import TopStripe from '../components/TopStripe.astro';
import Button from '../components/Button.astro';
import { t } from '../i18n/utils';

const locale = 'et' as const;

const images = [
  { src: '/fotopank/LaitseCastle_night_Toomas-Tuul.webp', alt: 'Laitse loss öösel' },
  { src: '/fotopank/LaitseLoss_Aiast_Toomas-Tuul.webp', alt: 'Loss aia poolt' },
  { src: '/fotopank/LaitseLoss_aed_Toomas-Tuul.webp', alt: 'Lossi aed' },
  { src: '/fotopank/LaitseLoss_park1.webp', alt: 'Lossipark' },
  { src: '/fotopank/LaitseLoss_myyr.webp', alt: 'Lossimüür' },
  { src: '/fotopank/LaitseLoss_terrass_Toomas-Tuul.webp', alt: 'Terrass' },
  { src: '/fotopank/LaitseLoss_Terrass1.webp', alt: 'Terrass' },
  { src: '/fotopank/LaitseLoss_Terrass2a.webp', alt: 'Terrass' },
  { src: '/fotopank/LaitseLoss_Fuajee1.webp', alt: 'Fuajee' },
  { src: '/fotopank/LaitseLoss_Trepikoda1.webp', alt: 'Trepikoda' },
  { src: '/fotopank/LaitseLoss_Salong1.webp', alt: 'Salong' },
  { src: '/fotopank/LaitseLoss_Salong2.webp', alt: 'Salong' },
  { src: '/fotopank/LaitseLoss_Salong3.webp', alt: 'Salong' },
  { src: '/fotopank/LaitseLoss_klaverisalong_Toomas-Tuul.webp', alt: 'Klaverisalong' },
  { src: '/fotopank/LaitseLoss_Soogisaal1a.webp', alt: 'Pidulik söögisaal' },
  { src: '/fotopank/LaitseLoss_Soogisaal2.webp', alt: 'Pidulik söögisaal' },
  { src: '/fotopank/LaitseLoss_Soogisaal3.webp', alt: 'Pidulik söögisaal' },
  { src: '/fotopank/LaitseLoss_Peosaal1.webp', alt: 'Suur peosaal' },
  { src: '/fotopank/LaitseLoss_Seminar1.webp', alt: 'Seminariruum' },
  { src: '/fotopank/LaitseLoss_Seminar2a.webp', alt: 'Seminariruum' },
  { src: '/fotopank/LaitseLoss_seminarid-firmayritused.webp', alt: 'Seminarid ja firmaüritused' },
  { src: '/fotopank/LaitseLoss_Kohvik1.webp', alt: 'Kohvik' },
  { src: '/fotopank/LaitseLoss_Kohvik2.webp', alt: 'Kohvik' },
  { src: '/fotopank/LaitseLoss_Stuudiokook_Toomas-Tuul.webp', alt: 'Stuudioköök' },
  { src: '/fotopank/LaitseLoss_Stuudiokook2.webp', alt: 'Stuudioköök' },
  { src: '/fotopank/LaitseLoss_Labyrint1.webp', alt: 'Labürint' },
  { src: '/fotopank/LaitseLoss_Labyrint2.webp', alt: 'Labürint' },
  { src: '/fotopank/LaitseLoss_Labyrint3.webp', alt: 'Labürint' },
  { src: '/fotopank/LaitseLoss_motikad.webp', alt: 'Mootorrattad lossi juures' },
];
---

<BaseLayout
  title={t(locale, 'gallery.meta.title')}
  description={t(locale, 'gallery.meta.description')}
  locale="et"
  ogImage="/fotopank/LaitseCastle_Toomas-Tuul.webp"
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] md:min-h-[68vh] flex items-start justify-center overflow-hidden">
    <TopStripe />
    <img
      src="/fotopank/LaitseCastle_Toomas-Tuul.webp"
      alt={t(locale, 'gallery.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-10 text-center px-6 pt-28 md:pt-32 pb-10 max-w-2xl mx-auto">
      <h1 class="font-display text-hero text-warm-white text-overlay hero-enter" style="--delay: 0ms">
        {t(locale, 'gallery.hero.heading')}
      </h1>
    </div>
  </section>

  <!-- Intro text -->
  <section class="section-fade-from-dark px-6 pt-14 md:pt-20 text-center" data-animate>
    <p class="font-subtitle text-[clamp(26px,3.4vw,40px)] text-burgundy max-w-2xl mx-auto leading-snug">
      {t(locale, 'gallery.hero.subtitle')}
    </p>
  </section>

  <!-- Gallery grid -->
  <section class="px-6 pt-8 pb-16 md:pt-10 md:pb-24">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {images.map((img, i) => (
          <div class="group overflow-hidden rounded" data-animate data-animate-delay={(i % 3) * 100}>
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-64 md:h-72 object-cover group-hover:scale-[1.05] transition-transform duration-700"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="kontakt" class="bg-warm-light px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <p class="font-body text-body-lg text-stone mt-6 mb-8 leading-relaxed">{t(locale, 'gallery.intro.body')}</p>
      <Button variant="filled" href="/peod" label={t(locale, 'cta.contact')} />
    </div>
  </section>
</BaseLayout>
