---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import TopStripe from '../components/TopStripe.astro';
import Button from '../components/Button.astro';
import { t } from '../i18n/utils';

const locale = 'et' as const;

const images = [
  { src: '/fotopank/loss-oosel.webp', alt: 'Laitse loss öösel' },
  { src: '/fotopank/aiast.webp', alt: 'Loss aia poolt' },
  { src: '/fotopank/aed.webp', alt: 'Lossi aed' },
  { src: '/fotopank/park.webp', alt: 'Lossipark' },
  { src: '/fotopank/myyr.webp', alt: 'Lossimüür' },
  { src: '/fotopank/terrass.webp', alt: 'Terrass' },
  { src: '/fotopank/terrass1.webp', alt: 'Terrass' },
  { src: '/fotopank/terrass2.webp', alt: 'Terrass' },
  { src: '/fotopank/fuajee.webp', alt: 'Fuajee' },
  { src: '/fotopank/trepikoda.webp', alt: 'Trepikoda' },
  { src: '/fotopank/salong1.webp', alt: 'Salong' },
  { src: '/fotopank/salong2.webp', alt: 'Salong' },
  { src: '/fotopank/salong3.webp', alt: 'Salong' },
  { src: '/fotopank/klaverisalong.webp', alt: 'Klaverisalong' },
  { src: '/fotopank/soogisaal1.webp', alt: 'Pidulik söögisaal' },
  { src: '/fotopank/soogisaal2.webp', alt: 'Pidulik söögisaal' },
  { src: '/fotopank/soogisaal3.webp', alt: 'Pidulik söögisaal' },
  { src: '/fotopank/peosaal.webp', alt: 'Suur peosaal' },
  { src: '/fotopank/seminar1.webp', alt: 'Seminariruum' },
  { src: '/fotopank/seminar2.webp', alt: 'Seminariruum' },
  { src: '/fotopank/seminarid.webp', alt: 'Seminarid ja firmaüritused' },
  { src: '/fotopank/kohvik1.webp', alt: 'Kohvik' },
  { src: '/fotopank/kohvik2.webp', alt: 'Kohvik' },
  { src: '/fotopank/stuudiokook.webp', alt: 'Stuudioköök' },
  { src: '/fotopank/stuudiokook2.webp', alt: 'Stuudioköök' },
  { src: '/fotopank/labyrint1.webp', alt: 'Labürint' },
  { src: '/fotopank/labyrint2.webp', alt: 'Labürint' },
  { src: '/fotopank/labyrint3.webp', alt: 'Labürint' },
  { src: '/fotopank/motikad.webp', alt: 'Mootorrattad lossi juures' },
];
---

<BaseLayout
  title={t(locale, 'gallery.meta.title')}
  description={t(locale, 'gallery.meta.description')}
  locale="et"
  ogImage="/fotopank/loss.webp"
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] md:min-h-[68vh] flex items-center justify-center overflow-hidden">
    <TopStripe />
    <img
      src="/fotopank/loss.webp"
      alt={t(locale, 'gallery.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-10 text-center px-6 py-20 max-w-2xl mx-auto">
      <h1 class="font-display text-hero text-warm-white mb-5 text-overlay hero-enter" style="--delay: 0ms">
        {t(locale, 'gallery.hero.heading')}
      </h1>
      <p class="font-subtitle text-subtitle italic text-warm-white/90 text-overlay hero-enter" style="--delay: 150ms">
        {t(locale, 'gallery.hero.subtitle')}
      </p>
    </div>
  </section>

  <!-- Gallery grid -->
  <section class="section-fade-from-dark px-6 py-16 md:py-24">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {images.map((img, i) => (
          <div class="group overflow-hidden rounded" data-animate data-animate-delay={(i % 3) * 100}>
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-64 md:h-72 object-cover group-hover:scale-[1.05] transition-transform duration-700"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="kontakt" class="bg-warm-light px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <p class="font-body text-body-lg text-stone mt-6 mb-8 leading-relaxed">{t(locale, 'gallery.intro.body')}</p>
      <Button variant="filled" href="/peod" label={t(locale, 'cta.contact')} />
    </div>
  </section>
</BaseLayout>
