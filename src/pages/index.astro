---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import GoldRule from '../components/GoldRule.astro';
import BurgundyRule from '../components/BurgundyRule.astro';
import TopStripe from '../components/TopStripe.astro';
import Button from '../components/Button.astro';

const eventVenueSchema = {
  "@context": "https://schema.org",
  "@type": ["EventVenue", "LocalBusiness"],
  "@id": "https://laitseloss.ee/#venue",
  "name": "Laitse Loss",
  "alternateName": "Laitse Castle",
  "description": "Ajalooline neogooti loss Harjumaal — ideaalne koht pulmadeks, pidudeks, seminarideks ja konverentsideks. Vaid 30 minutit Tallinnast.",
  "url": "https://laitseloss.ee",
  "telephone": "+37258356509",
  "email": "info@laitseloss.ee",
  "image": [
    "https://laitseloss.ee/images/Fassaad.jpg",
    "https://laitseloss.ee/images/Pulmad.jpg",
    "https://laitseloss.ee/images/Suur_saal_galerii.jpg"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lossi tee 9",
    "addressLocality": "Laitse",
    "postalCode": "76302",
    "addressRegion": "Harjumaa",
    "addressCountry": "EE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 59.1966,
    "longitude": 24.3846
  },
  "hasMap": "https://maps.google.com/?q=59.1966,24.3846",
  "maximumAttendeeCapacity": 150,
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Tasuta parkimine", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "WiFi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Projektor ja ekraan", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Terrass", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Aed", "value": true }
  ],
  "containsPlace": [
    {
      "@type": "MeetingRoom",
      "@id": "https://laitseloss.ee/#suur-saal",
      "name": "Suur saal",
      "description": "Lossi suurim ruum kõrgete võlvlagedega. Sobib suursugusteks banketipidudeks, kontsertideks ja konverentsideks.",
      "floorSize": {
        "@type": "QuantitativeValue",
        "value": 110,
        "unitCode": "MTK"
      },
      "maximumAttendeeCapacity": 150
    },
    {
      "@type": "MeetingRoom",
      "@id": "https://laitseloss.ee/#salong",
      "name": "Salong",
      "description": "Intiimne esimese korruse salong suure aknaga lossi aeda. Sobib väiksematele tähistamistele ja seminaridele.",
      "floorSize": {
        "@type": "QuantitativeValue",
        "value": 56,
        "unitCode": "MTK"
      },
      "maximumAttendeeCapacity": 64
    }
  ],
  "parentOrganization": {
    "@id": "https://laitseloss.ee/#organization"
  }
};
---

<BaseLayout
  title="Laitse Loss — Ajalooline sündmuste paik Harjumaal"
  description="Neogooti loss Harjumaal — elegantne sündmuskoht pulmadeks, pidudeks ja seminarideks. Vaid 30 minutit Tallinnast. Tutvu ruumide ja võimalustega."
  pageSchema={eventVenueSchema}
>

  <!-- ═══════════════════════════════════════════
       1. HERO — Clean, image-driven
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[85vh] flex flex-col items-center justify-center overflow-hidden">
    <TopStripe />

    <img
      src="/images/Fassaad.jpg"
      alt="Laitse lossi fassaad"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
      decoding="async"
      width="1440"
      height="900"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-warm-dark/90 via-warm-dark/65 to-warm-dark/40"></div>

    <div class="relative z-10 flex flex-col items-center text-center gap-5 max-w-2xl px-6 py-24">
      <Flourish type="simple" size="sm" fill="gold" />

      <h1 class="font-display text-[clamp(44px,7vw,80px)] text-warm-white mt-4 drop-shadow-lg leading-[1.05]">Laitse Loss</h1>

      <GoldRule width="80px" />

      <p class="font-subtitle italic text-subtitle text-warm-white drop-shadow-md">
        Ajalooline sündmuste paik Harjumaal
      </p>

      <p class="font-body text-body-lg text-warm-white/90 max-w-lg mt-2 drop-shadow-sm leading-relaxed">
        Neogooti loss keset Harjumaa loodust — pulmadeks, pidustusteks ja seminarideks. Vaid 30 minutit Tallinnast.
      </p>

      <div class="flex flex-wrap items-center gap-8 justify-center mt-6">
        <Button variant="filled" href="mailto:info@laitseloss.ee" label="Küsi pakkumist" />
        <a href="/peod" class="font-ui text-[15px] uppercase tracking-wider text-warm-white border-b border-warm-white/40 pb-1 hover:border-warm-white transition-colors">
          Avasta ruume &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       2. STATS STRIP — Compact, elegant
       ═══════════════════════════════════════════ -->
  <section class="border-b border-stone/10">
    <div class="max-w-5xl mx-auto grid grid-cols-3 divide-x divide-stone/10">
      <div class="py-8 md:py-10 text-center">
        <p class="font-display text-[clamp(28px,3.5vw,40px)] text-burgundy leading-none">130+</p>
        <p class="font-ui text-[11px] md:text-label-sm uppercase tracking-wider text-stone mt-1">aastat ajalugu</p>
      </div>
      <div class="py-8 md:py-10 text-center">
        <p class="font-display text-[clamp(28px,3.5vw,40px)] text-burgundy leading-none"><span class="text-[0.55em] font-ui tracking-normal align-baseline">kuni&nbsp;</span>150</p>
        <p class="font-ui text-[11px] md:text-label-sm uppercase tracking-wider text-stone mt-1">külalist</p>
      </div>
      <div class="py-8 md:py-10 text-center">
        <p class="font-display text-[clamp(28px,3.5vw,40px)] text-burgundy leading-none">30<span class="text-[0.6em]"> min</span></p>
        <p class="font-ui text-[11px] md:text-label-sm uppercase tracking-wider text-stone mt-1">Tallinnast</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       3. TEENUSED — Asymmetric, visual
       ═══════════════════════════════════════════ -->
  <section class="py-20 md:py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8">

        <!-- Peod — large featured card -->
        <a href="/peod" class="md:col-span-7 group relative overflow-hidden rounded block hover:-translate-y-1 hover:shadow-2xl transition-all duration-500">
          <img
            src="/images/Pulmad.jpg"
            alt="Pulmatseremoonia Laitse lossis"
            class="w-full h-[400px] md:h-[520px] object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-warm-dark/95 via-warm-dark/50 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10 text-overlay">
            <div class="w-12 h-[2px] bg-gold-gradient-h mb-5"></div>
            <p class="font-ui text-[13px] uppercase tracking-wider text-gold-light mb-2 font-normal">Peod ja tähtpäevad</p>
            <h2 class="font-display text-[clamp(26px,3vw,36px)] text-warm-white mb-3 leading-tight">
              Pulmad, sünnipäevad ja pidustused
            </h2>
            <p class="font-body text-body text-warm-white/90 mb-6 max-w-md">
              Lossi elegantne atmosfäär teeb iga tähistamise eriliseks.
            </p>
            <span class="font-ui text-[14px] uppercase tracking-wider text-warm-white border-b border-warm-white/40 pb-1 group-hover:border-warm-white transition-colors">
              Avasta &rarr;
            </span>
          </div>
        </a>

        <!-- Right column: Seminarid + Asukoht stacked -->
        <div class="md:col-span-5 flex flex-col gap-6 md:gap-8">

          <!-- Seminarid card -->
          <a href="/seminarid" class="group relative overflow-hidden rounded flex-1 block hover:-translate-y-1 hover:shadow-2xl transition-all duration-500">
            <img
              src="/images/Suur_saal_galerii.jpg"
              alt="Seminariruumid Laitse lossis"
              class="w-full h-[240px] md:h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-warm-dark/95 via-warm-dark/50 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-overlay">
              <div class="w-10 h-[2px] bg-gold-gradient-h mb-4"></div>
              <p class="font-ui text-[13px] uppercase tracking-wider text-gold-light mb-2 font-normal">Seminarid</p>
              <h2 class="font-display text-[clamp(22px,2.5vw,28px)] text-warm-white mb-3 leading-tight">
                Konverentsid ja koolitused
              </h2>
              <span class="font-ui text-[14px] uppercase tracking-wider text-warm-white border-b border-warm-white/40 pb-1 group-hover:border-warm-white transition-colors">
                Avasta &rarr;
              </span>
            </div>
          </a>

          <!-- Location mini-card -->
          <div class="bg-warm-light rounded p-6 md:p-8">
            <p class="font-ui text-label-sm uppercase tracking-wider text-burgundy mb-3">Asukoht</p>
            <p class="font-body text-body-lg text-warm-dark leading-relaxed">
              Lossi tee 9, Laitse, Harjumaa
            </p>
            <p class="font-body text-body text-stone mt-1">
              30 min Tallinnast &middot; tasuta parkimine
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       4. LOSSI LUGU — Full-bleed immersive
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[50vh] md:min-h-[60vh] flex items-center overflow-hidden">
    <img
      src="/images/Lossi-tornid.jpg"
      alt="Laitse lossi tornid"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-warm-dark/75"></div>

    <div class="relative z-10 max-w-2xl mx-auto px-6 py-20 md:py-28 text-center text-overlay">
      <p class="font-ui text-label-sm uppercase tracking-[0.2em] text-gold-light mb-5">Alates 1219</p>
      <h2 class="font-display text-[clamp(28px,4vw,44px)] text-warm-white mb-8 leading-tight">
        Lossi lugu
      </h2>
      <p class="font-body text-body-lg text-warm-white/90 mb-6 leading-relaxed">
        Laitse nimi ilmub ajaloo lehekülgedele esmakordselt 1219. aastal Henriku Liivimaa kroonikas.
        Sajandeid hiljem, 1890. aastal, ehitas baltisaksa aadlik Woldemar von Uexküll siia neogooti
        lossihoone — tornikeste ja kunstipäraste detailidega ehitise, mis paistab juba kaugelt.
      </p>
      <p class="font-body text-body-lg text-warm-white/80 mb-10 leading-relaxed">
        Sõjaväelasest kirjanikuks ja usuliseks müstikuks saanud Woldemari sisemine maailm peegeldub
        hoone ülevas ilmes. Kodu, mis sai lossiks.
      </p>
      <a href="/ajalugu" class="font-ui text-[15px] uppercase tracking-wider text-warm-white border-b border-warm-white/40 pb-1 hover:border-warm-white transition-colors">
        Loe edasi &rarr;
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       5. CTA
       ═══════════════════════════════════════════ -->
  <section class="py-20 md:py-28 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">Räägime teie sündmusest</h2>
      <p class="font-body text-body-lg text-stone mb-8 leading-relaxed">
        Iga sündmus on erinev. Rääkige meile oma soovidest
        ja leiame koos parima lahenduse.
      </p>

      <div class="mb-10">
        <a href="tel:+37258356509" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors inline-flex items-center gap-2 min-h-[44px]">
          <span class="text-stone">Tel:</span> +372 58 356 509
        </a>
        <a href="mailto:info@laitseloss.ee" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors flex items-center justify-center gap-2 min-h-[44px]">
          <span class="text-stone">E-post:</span> info@laitseloss.ee
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  section:first-of-type :global(a.border-burgundy) {
    border-color: rgba(250, 247, 242, 0.5);
    color: #FAF7F2;
  }
  section:first-of-type :global(a.border-burgundy:hover) {
    background-color: rgba(250, 247, 242, 0.12);
    border-color: #FAF7F2;
    color: #FAF7F2;
  }
</style>

