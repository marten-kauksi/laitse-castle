---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import GoldRule from '../components/GoldRule.astro';
import TopStripe from '../components/TopStripe.astro';
import Button from '../components/Button.astro';
import { t } from '../i18n/utils';

const locale = 'et' as const;

const eventVenueSchema = {
  "@context": "https://schema.org",
  "@type": ["EventVenue", "LocalBusiness"],
  "@id": "https://laitsecastle.ee/#venue",
  "name": "Laitse loss",
  "alternateName": "Laitse Castle",
  "description": "Ajalooline neogooti loss Harjumaal — ideaalne koht pulmadeks, pidudeks, seminarideks ja konverentsideks. ~40 minutit Tallinnast.",
  "url": "https://laitsecastle.ee",
  "telephone": "+37254210881",
  "email": "info@laitsecastle.ee",
  "image": [
    "https://laitsecastle.ee/images/hero-main-image.jpg",
    "https://laitsecastle.ee/signed-images/loss-oosel.webp",
    "https://laitsecastle.ee/images/saal.jpg"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lossi tee 9",
    "addressLocality": "Laitse",
    "postalCode": "76302",
    "addressRegion": "Harjumaa",
    "addressCountry": "EE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 59.1966,
    "longitude": 24.3846
  },
  "hasMap": "https://maps.google.com/?q=59.1966,24.3846",
  "maximumAttendeeCapacity": 100,
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Tasuta parkimine", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "WiFi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Projektor ja ekraan", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Terrass", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Aed", "value": true }
  ],
  "containsPlace": [
    {
      "@type": "MeetingRoom",
      "@id": "https://laitsecastle.ee/#peasaal",
      "name": "Peasaal",
      "maximumAttendeeCapacity": 100
    },
    {
      "@type": "MeetingRoom",
      "@id": "https://laitsecastle.ee/#klaverisalong",
      "name": "Klaverisalong",
      "maximumAttendeeCapacity": 64
    },
    {
      "@type": "MeetingRoom",
      "@id": "https://laitsecastle.ee/#suur-saal",
      "name": "Suur saal"
    }
  ],
  "parentOrganization": {
    "@id": "https://laitsecastle.ee/#organization"
  }
};
---

<BaseLayout
  title={t(locale, 'home.meta.title')}
  description={t(locale, 'home.meta.description')}
  locale="et"
  pageSchema={eventVenueSchema}
>

  <!-- ═══════════════════════════════════════════
       1. HERO
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-start overflow-hidden">
    <TopStripe />

    <img
      src="/fotopank/LaitseCastle_Toomas-Tuul.webp"
      alt={t(locale, 'home.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover object-[center_25%]"
      fetchpriority="high"
      decoding="async"
    />

    <div class="relative z-10 flex flex-col items-center text-center gap-5 max-w-2xl px-6 pt-28 md:pt-32">
      <h1 class="hero-enter font-display text-[clamp(44px,7vw,80px)] text-warm-white leading-[1.05]" style="--delay: 100ms; text-shadow: 0 2px 24px rgba(0,0,0,0.95), 0 1px 4px rgba(0,0,0,0.9)">{t(locale, 'home.hero.title')}</h1>

      <p class="hero-enter font-subtitle font-bold italic text-[clamp(22px,2.6vw,30px)] text-warm-white" style="--delay: 300ms; text-shadow: 0 2px 16px rgba(0,0,0,0.95), 0 1px 3px rgba(0,0,0,0.95)">
        {t(locale, 'home.hero.subtitle')}
      </p>

      <div class="hero-enter mt-6" style="--delay: 450ms">
        <Button variant="filled" href="#kontakt" label={t(locale, 'cta.contact')} />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       1b. SUVETERRAS — announcement band
       ═══════════════════════════════════════════ -->
  <section class="bg-warm-white px-6 py-8 md:py-10">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-subtitle font-semibold text-[clamp(22px,2.6vw,32px)] text-burgundy leading-snug">{t(locale, 'home.terrace.line1')}</p>
      <p class="font-body text-body-lg text-warm-dark mt-2">{t(locale, 'home.terrace.line2')}</p>
      <a href="/menuu" class="group inline-flex items-center gap-2 mt-5 min-h-[44px] font-display text-[clamp(22px,2.4vw,28px)] text-burgundy hover:text-warm-dark transition-colors">
        <span class="border-b-2 border-gold pb-0.5">Menüü</span>
        <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       2. TEENUSED — Two equal cards
       ═══════════════════════════════════════════ -->
  <section class="section-fade-from-dark pt-12 md:pt-16 pb-20 md:pb-28 px-6">
    <div class="max-w-2xl mx-auto text-center mb-12" data-animate>
      <h2 class="font-display text-section text-warm-dark mb-5">{t(locale, 'home.services.heading')}</h2>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <p class="font-body text-body-lg text-stone mt-6 leading-relaxed">{t(locale, 'home.services.subtitle')}</p>
    </div>
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8">

        <!-- Sünnipäevad, pidustused ja pulmad — large featured card -->
        <a href="/peod" class="service-card md:col-span-7 group relative overflow-hidden rounded block" data-animate data-animate-delay="100">
          <img
            src="/fotopank/LaitseLoss_Terrass1.webp"
            alt={t(locale, 'home.services.card1.imageAlt')}
            class="w-full h-[400px] md:h-[520px] object-cover group-hover:scale-[1.03] transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10 text-overlay">
            <div class="w-12 group-hover:w-14 h-[2px] bg-gold-gradient-h mb-5 transition-all duration-500"></div>
            <h2 class="font-display text-[clamp(26px,3vw,36px)] text-warm-white leading-tight" style="text-shadow: 0 2px 18px rgba(0,0,0,0.9), 0 1px 5px rgba(0,0,0,0.95), 0 0 2px rgba(0,0,0,0.85)">
              {t(locale, 'home.services.card1.title')}
            </h2>
          </div>
        </a>

        <!-- Right column: Firmaüritused ja seminarid -->
        <div class="md:col-span-5 flex flex-col gap-6 md:gap-8">

          <!-- Firmaüritused ja seminarid card -->
          <a href="/seminarid" class="service-card group relative overflow-hidden rounded flex-1 block" data-animate data-animate-delay="250">
            <img
              src="/fotopank/LaitseLoss_seminarid-firmayritused.webp"
              alt={t(locale, 'home.services.card2.imageAlt')}
              class="w-full h-[240px] md:h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
              loading="lazy"
            />
              <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-overlay">
              <div class="w-10 group-hover:w-12 h-[2px] bg-gold-gradient-h mb-4 transition-all duration-500"></div>
              <h2 class="font-display text-[clamp(22px,2.5vw,28px)] text-warm-white leading-tight" style="text-shadow: 0 2px 18px rgba(0,0,0,0.9), 0 1px 5px rgba(0,0,0,0.95), 0 0 2px rgba(0,0,0,0.85)">
                {t(locale, 'home.services.card2.title')}
              </h2>
            </div>
          </a>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       2b. MEELEOLUKAS KOOSVIIBIMINE — two linked cards
       ═══════════════════════════════════════════ -->
  <section class="bg-warm-white px-6 pb-20 md:pb-28">
    <div class="max-w-2xl mx-auto text-center mb-12" data-animate>
      <h2 class="font-display text-section text-warm-dark mb-5">Meeleolukas koosviibimine</h2>
      <Flourish type="vintage" size="sm" fill="burgundy" />
    </div>
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

      <!-- Mõrvamüsteerium -->
      <a href="/lisateenused/morvamysteerium" class="service-card group relative overflow-hidden rounded block" data-animate data-animate-delay="100">
        <img
          src="/fotopank/LaitseLoss_mysteerium1a_Katrin-Luts.webp"
          alt="Mõrvamüsteerium Laitse lossis"
          class="w-full h-[360px] md:h-[460px] object-cover object-[center_60%] group-hover:scale-[1.03] transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10 text-overlay">
          <div class="w-12 group-hover:w-14 h-[2px] bg-gold-gradient-h mb-5 transition-all duration-500"></div>
          <h3 class="font-display text-[clamp(24px,2.8vw,32px)] text-warm-white leading-tight" style="text-shadow: 0 2px 18px rgba(0,0,0,0.9), 0 1px 5px rgba(0,0,0,0.95), 0 0 2px rgba(0,0,0,0.85)">
            Mõrvamüsteerium
          </h3>
        </div>
      </a>

      <!-- Šokolaaditrühvlite valmistamine -->
      <a href="/lisateenused/sokolaadikoolitus" class="service-card group relative overflow-hidden rounded block" data-animate data-animate-delay="250">
        <img
          src="/fotopank/LaitseLoss_tryhvlid2_Krista-Ruben.webp"
          alt="Šokolaaditrühvlite valmistamine Laitse lossis"
          class="w-full h-[360px] md:h-[460px] object-cover group-hover:scale-[1.03] transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10 text-overlay">
          <div class="w-12 group-hover:w-14 h-[2px] bg-gold-gradient-h mb-5 transition-all duration-500"></div>
          <h3 class="font-display text-[clamp(24px,2.8vw,32px)] text-warm-white leading-tight" style="text-shadow: 0 2px 18px rgba(0,0,0,0.9), 0 1px 5px rgba(0,0,0,0.95), 0 0 2px rgba(0,0,0,0.85)">
            Šokolaaditrühvlite valmistamine
          </h3>
        </div>
      </a>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       NÄITUS — Olga Makina moefotode näitus
       ═══════════════════════════════════════════ -->
  <section class="bg-warm-white px-6 pb-20 md:pb-28">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10" data-animate>
        <p class="font-ui text-[15px] font-bold uppercase tracking-[0.2em] text-gold mb-4">Näitus</p>
        <h2 class="font-display text-section text-warm-dark leading-tight mb-5">
          Olga Makina moefotode näitus
        </h2>
        <Flourish type="vintage" size="sm" fill="burgundy" />
      </div>
      <div class="overflow-hidden rounded" data-animate data-animate-delay="100">
        <img
          src="/fotopank/LaitseCastle_Olga-Makina-naitus2a.webp"
          alt="Olga Makina moefotode näitus Laitse lossi saalis"
          class="w-full h-auto"
          loading="lazy"
        />
      </div>
      <p class="font-body text-body-lg text-warm-dark leading-relaxed mt-8 text-center" data-animate data-animate-delay="150">
        Fotograaf Olga Makina tähistab moefotode näitusega oma 30 aastat fotograafias. Näitus on üles seatud Laitse lossi esimese korruse saalidesse. Saate näitust tasuta uudistada kohviku lahtioleku aegadel.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       3. HEKKLABÜRINT — Tuhande tuti mägi teaser
       ═══════════════════════════════════════════ -->
  <section class="bg-warm-white px-6 pb-20 md:pb-28">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">

      <div class="overflow-hidden rounded" data-animate>
        <img
          src="/fotopank/LaitseLoss_Labyrint3.webp"
          alt="Laitse lossi hekklabürint — Tuhande tuti mägi"
          class="w-full h-72 md:h-[460px] object-cover"
          loading="lazy"
        />
      </div>

      <div data-animate data-animate-delay="150">
        <h2 class="font-display text-section text-warm-dark leading-tight mb-5">
          Tuhande tuti mägi – Laitse lossi hekklabürint
        </h2>
        <GoldRule width="60px" />
        <p class="font-body text-body-lg text-warm-dark leading-relaxed mt-6 mb-8">
          Lossi kõrvale on rajatud omanäoline, madalatest elupuudest koosnev kuplikujuline hekklabürint, kuhu on istutatud veidi üle tuhande puu.
        </p>
        <Button variant="outline" href="/hekklabyrint" label="Loe edasi" />
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       4. LOSSI LUGU — Image left, text right
       ═══════════════════════════════════════════ -->
  <section class="bg-warm-white px-6 pb-20 md:pb-28">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">

      <div class="overflow-hidden rounded" data-animate>
        <img
          src="/signed-images/lossi-torn-ajalugu.webp"
          alt={t(locale, 'home.story.imageAlt')}
          class="w-full h-72 md:h-[460px] object-cover"
          loading="lazy"
        />
      </div>

      <div data-animate data-animate-delay="150">
        <p class="font-ui text-label-sm uppercase tracking-[0.2em] text-burgundy mb-4">{t(locale, 'home.story.eyebrow')}</p>
        <h2 class="font-display text-section text-warm-dark leading-tight mb-5">
          {t(locale, 'home.story.heading')}
        </h2>
        <GoldRule width="60px" />
        <p class="font-body text-body-lg text-warm-dark leading-relaxed mt-6 mb-4">
          {t(locale, 'home.story.p1')}
        </p>
        <p class="font-body text-body-lg text-warm-dark leading-relaxed mb-8">
          {t(locale, 'home.story.p2')}
        </p>
        <Button variant="outline" href="/ajalugu" label={t(locale, 'home.story.cta')} />
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       5. CTA
       ═══════════════════════════════════════════ -->
  <section id="kontakt" class="section-fade-from-dark py-20 md:py-28 px-6">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">{t(locale, 'cta.bookEvent')}</h2>
      <p class="font-body text-body-lg text-stone mb-8 leading-relaxed">
        {t(locale, 'cta.bookEventDesc')}
      </p>

      <div class="mb-10">
        <a href="tel:+37254210881" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors inline-flex items-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.tel')}</span> +372 5421 0881
        </a>
        <a href="mailto:info@laitsecastle.ee" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors flex items-center justify-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.email')}</span> info@laitsecastle.ee
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  section:first-of-type :global(a.border-burgundy) {
    border-color: rgba(250, 247, 242, 0.5);
    color: #FAF7F2;
  }
  section:first-of-type :global(a.border-burgundy:hover) {
    background-color: rgba(250, 247, 242, 0.12);
    border-color: #FAF7F2;
    color: #FAF7F2;
  }
</style>
