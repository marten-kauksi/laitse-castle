---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import TopStripe from '../components/TopStripe.astro';
import Button from '../components/Button.astro';
import { t } from '../i18n/utils';

const locale = 'et' as const;

const features = ['item1', 'item2', 'item3'];
---

<BaseLayout
  title={t(locale, 'seminars.meta.title')}
  description={t(locale, 'seminars.meta.description')}
  locale="et"
  ogImage="/fotopank/LaitseLoss_seminarid-firmayritused.webp"
>
  <!-- Hero -->
  <section class="relative min-h-[70vh] md:min-h-[78vh] flex items-center justify-center overflow-hidden">
    <TopStripe />
    <img
      src="/fotopank/LaitseLoss_seminarid-firmayritused.webp"
      alt={t(locale, 'seminars.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-10 text-center px-6 py-24 max-w-2xl mx-auto">
      <h1 class="font-display text-hero text-warm-white mb-8 text-overlay hero-enter" style="--delay: 0ms">
        {t(locale, 'seminars.hero.heading')}
      </h1>
      <div class="hero-enter mt-2" style="--delay: 150ms">
        <Button variant="filled" href="#kontakt" label={t(locale, 'cta.contact')} />
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section-fade-from-dark px-6 py-20 md:py-28">
    <div class="max-w-3xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-display text-section text-warm-dark mt-6 mb-5">{t(locale, 'seminars.intro.heading')}</h2>
      <p class="font-body text-body-lg text-stone leading-relaxed">{t(locale, 'seminars.intro.body')}</p>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-warm-light px-6 py-20 md:py-28">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12" data-animate>
        <h2 class="font-display text-section text-warm-dark mb-5">{t(locale, 'seminars.features.heading')}</h2>
        <Flourish type="vintage" size="sm" fill="burgundy" />
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {features.map((key, i) => (
          <div class="text-center" data-animate data-animate-delay={(i + 1) * 120}>
            <span class="text-gold text-2xl" aria-hidden="true">&#9830;</span>
            <h3 class="font-subtitle text-[clamp(20px,2.2vw,26px)] text-warm-dark mt-3 mb-3">{t(locale, `seminars.features.${key}.title`)}</h3>
            <p class="font-body text-body text-stone leading-relaxed">{t(locale, `seminars.features.${key}.desc`)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="kontakt" class="px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">{t(locale, 'cta.bookEvent')}</h2>
      <p class="font-body text-body-lg text-stone mb-8 leading-relaxed">{t(locale, 'cta.bookEventDesc')}</p>
      <div class="mb-10">
        <a href="tel:+37253300206" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors inline-flex items-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.tel')}</span> +372 5330 0206
        </a>
        <a href="mailto:info@laitsecastle.ee" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors flex items-center justify-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.email')}</span> info@laitsecastle.ee
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
