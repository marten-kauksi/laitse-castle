---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import GoldRule from '../components/GoldRule.astro';
import { t } from '../i18n/utils';

const locale = 'et' as const;

const ajaluguSchema = {
  "@context": "https://schema.org",
  "@type": "LandmarksOrHistoricalBuildings",
  "@id": "https://laitsecastle.ee/#castle",
  "name": "Laitse Loss",
  "alternateName": ["Laitse Castle", "Laitse mõis"],
  "description": "Neogooti stiilis ajalooline lossihoone Harjumaal, Eestis. Ehitati umbes 1890. aastal Woldemar von Uexkülli poolt. Lossi asukoht on mainitud juba Henriku Liivimaa kroonikas aastast 1219.",
  "url": "https://laitsecastle.ee/ajalugu",
  "image": [
    "https://laitsecastle.ee/signed-images/lossi-torn-ajalugu.webp"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lossi tee 9",
    "addressLocality": "Laitse",
    "postalCode": "76302",
    "addressRegion": "Harjumaa",
    "addressCountry": "EE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 59.1966,
    "longitude": 24.3846
  },
  "foundingDate": "1890",
  "historicOccupant": [
    {
      "@type": "Person",
      "name": "Woldemar von Uexküll",
      "birthDate": "1860-08-28",
      "deathDate": "1945",
      "description": "Baltisaksa aadlik, Laitse lossihoone ehitaja. Sõjaväelane, kirjanik ja usutegelane."
    }
  ],
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Harjumaa",
    "addressCountry": "EE"
  }
};
---

<BaseLayout
  title={t(locale, 'history.meta.title')}
  description={t(locale, 'history.meta.description')}
  locale="et"
  ogImage="/signed-images/lossi-torn-ajalugu.webp"
  pageSchema={ajaluguSchema}
>

  <!-- ═══ HERO ═══ -->
  <section
    class="relative flex items-center justify-center min-h-[60vh] md:min-h-[70vh] bg-warm-dark overflow-hidden"
  >
    <img
      src="/signed-images/lossi-torn-ajalugu.webp"
      alt={t(locale, 'history.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="relative z-10 text-center text-overlay px-6 py-24 md:py-32">
      <h1 class="font-display text-hero text-warm-white mb-4 drop-shadow-lg hero-enter" style="--delay:0ms">
        {t(locale, 'history.hero.heading')}
      </h1>
      <div class="flex justify-center hero-enter" style="--delay:150ms">
        <GoldRule width="120px" />
      </div>
    </div>
  </section>

  <!-- ═══ CASTLE HISTORY NARRATIVE ═══ -->
  <section class="section-fade-from-dark py-20 md:py-28 px-6">
    <div class="max-w-prose mx-auto">

      <p class="font-body text-body-lg text-warm-dark leading-relaxed mb-8" data-animate>
        {t(locale, 'history.p1')}
      </p>

      <div class="flex justify-center my-14">
        <GoldRule width="100px" />
      </div>

      <p class="font-body text-body-lg text-warm-dark leading-relaxed mb-8" data-animate>
        {t(locale, 'history.p2')}
      </p>

      <div class="flex justify-center my-14">
        <GoldRule width="100px" />
      </div>

      <p class="font-body text-body-lg text-warm-dark leading-relaxed mb-8" data-animate>
        {t(locale, 'history.p3')}
      </p>

    </div>
  </section>

  <!-- ═══ FOOTER CTA ═══ -->
  <section class="py-20 md:py-28 px-6">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">{t(locale, 'cta.bookEvent')}</h2>
      <p class="font-body text-body-lg text-stone mb-8 leading-relaxed">
        {t(locale, 'cta.bookEventDesc')}
      </p>

      <div class="mb-10">
        <a href="tel:+37253300206" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors inline-flex items-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.tel')}</span> +372 5330 0206
        </a>
        <a href="mailto:info@laitsecastle.ee" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors flex items-center justify-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.email')}</span> info@laitsecastle.ee
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
