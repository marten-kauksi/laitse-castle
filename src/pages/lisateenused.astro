---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import TopStripe from '../components/TopStripe.astro';
import Button from '../components/Button.astro';
import { t } from '../i18n/utils';

const locale = 'et' as const;

// item3 (Meelelahutus) is expanded into its own section with sub-pages below
const items = ['item1', 'item2', 'item4', 'item5'];
---

<BaseLayout
  title={t(locale, 'addons.meta.title')}
  description={t(locale, 'addons.meta.description')}
  locale="et"
  ogImage="/fotopank/LaitseLoss_terrass_Toomas-Tuul.webp"
>
  <!-- Hero -->
  <section class="relative min-h-[70vh] md:min-h-[78vh] flex items-center justify-center overflow-hidden">
    <TopStripe />
    <img
      src="/fotopank/LaitseLoss_terrass_Toomas-Tuul.webp"
      alt={t(locale, 'addons.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover object-bottom"
    />
    <div class="relative z-10 text-center px-6 py-24 max-w-2xl mx-auto">
      <h1 class="font-display text-hero text-warm-white mb-6 text-overlay hero-enter" style="--delay: 0ms">
        {t(locale, 'addons.hero.heading')}
      </h1>
      <p class="font-subtitle font-bold italic text-[clamp(24px,3vw,34px)] text-warm-white mb-8 hero-enter" style="--delay: 150ms; text-shadow: 0 2px 14px rgba(0,0,0,0.98), 0 0 6px rgba(0,0,0,0.9), 0 1px 3px rgba(0,0,0,0.98)">
        {t(locale, 'addons.hero.subtitle')}
      </p>
      <div class="hero-enter mt-6" style="--delay: 300ms">
        <Button variant="filled" href="#kontakt" label={t(locale, 'cta.contact')} />
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section-fade-from-dark px-6 py-20 md:py-24">
    <div class="max-w-3xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-display text-section text-warm-dark mt-6 mb-5">{t(locale, 'addons.intro.heading')}</h2>
      <p class="font-body text-body-lg text-stone leading-relaxed">{t(locale, 'addons.intro.body')}</p>
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-warm-light px-6 py-20 md:py-28">
    <div class="max-w-5xl mx-auto">
      <div class="grid sm:grid-cols-2 gap-8 md:gap-10">
        {items.map((key, i) => (
          <div class="flex items-start gap-4" data-animate data-animate-delay={(i + 1) * 80}>
            <span class="text-gold text-xl mt-1" aria-hidden="true">&#9830;</span>
            <div>
              <h3 class="font-subtitle text-[clamp(20px,2.2vw,24px)] text-warm-dark mb-2">{t(locale, `addons.${key}.title`)}</h3>
              <p class="font-body text-body text-stone leading-relaxed">{t(locale, `addons.${key}.desc`)}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Meelelahutus — sub-pages -->
  <section class="px-6 py-20 md:py-28">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14" data-animate>
        <Flourish type="vintage" size="sm" fill="burgundy" />
        <h2 class="font-display text-section text-warm-dark mt-6">Meelelahutus</h2>
      </div>

      <!-- Mõrvamüsteerium -->
      <a href="/lisateenused/morvamysteerium" class="group block border-t border-stone/15 pt-10 mb-10" data-animate>
        <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-center">
          <div class="overflow-hidden rounded">
            <img src="/fotopank/LaitseLoss_mysteerium1a_Katrin-Luts.webp" alt="Mõrvamüsteerium Laitse lossis" class="w-full h-64 md:h-80 object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
          </div>
          <div>
            <h3 class="font-subtitle text-[clamp(26px,3.2vw,36px)] text-burgundy group-hover:text-burgundy-hover transition-colors mb-4">Mõrvamüsteerium</h3>
            <p class="font-body text-body-lg text-warm-dark mb-3">Mõrvamüsteeriumiga pidusöök sisaldab:</p>
            <ul class="space-y-2 mb-4">
              {[
                'kolmekäigulist pidusööki lossi saalides',
                'pokaal vahulist saabumisel',
                'pokaal veini',
                'müsteeriumi läbiviimist kogenud mängujuhiga',
                'soovi korral aksessuaaride laenutust',
              ].map((item) => (
                <li class="flex items-start gap-3 font-body text-body text-warm-dark">
                  <span class="text-gold mt-1" aria-hidden="true">&#9830;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p class="font-body text-body text-stone">Mõrvamüsteeriume viime läbi viies keeles: eesti-, inglise-, hispaania-, soome- ja venekeelsena. Müsteerium koos pidusöögiga kestab umbes 2,5 h.</p>
            <span class="inline-block mt-5 font-ui text-[15px] uppercase tracking-wider text-burgundy border-b border-burgundy/40 pb-1 group-hover:border-burgundy transition-colors">Loe lähemalt →</span>
          </div>
        </div>
      </a>

      <!-- Šokolaaditrühvlite koolitus -->
      <a href="/lisateenused/sokolaadikoolitus" class="group block border-t border-stone/15 pt-10" data-animate>
        <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-center">
          <div class="overflow-hidden rounded">
            <img src="/fotopank/LaitseLoss_tryhvlid2_Krista-Ruben.webp" alt="Šokolaaditrühvlid" class="w-full h-64 md:h-72 object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
          </div>
          <div>
            <h3 class="font-subtitle text-[clamp(26px,3.2vw,36px)] text-burgundy group-hover:text-burgundy-hover transition-colors mb-4">Šokolaaditrühvlite valmistamise koolitus</h3>
            <p class="font-body text-body-lg text-warm-dark">Trühvlitegu on tore ettevõtmine, mida saab nautida nii üksinda kui ka mitmekesi koos. Tore on seda teha koos töökaaslaste või lihtsalt sõpradega, sest see tegevus võib olla ka suurepärane meeskonnatöö.</p>
            <span class="inline-block mt-5 font-ui text-[15px] uppercase tracking-wider text-burgundy border-b border-burgundy/40 pb-1 group-hover:border-burgundy transition-colors">Loe lähemalt →</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section id="kontakt" class="bg-warm-light px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">{t(locale, 'cta.bookEvent')}</h2>
      <p class="font-body text-body-lg text-stone mb-8 leading-relaxed">{t(locale, 'cta.bookEventDesc')}</p>
      <div class="mb-10">
        <a href="tel:+37254210881" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors inline-flex items-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.tel')}</span> +372 5421 0881
        </a>
        <a href="mailto:info@laitsecastle.ee" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors flex items-center justify-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.email')}</span> info@laitsecastle.ee
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
