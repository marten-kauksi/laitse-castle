---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import GoldRule from '../components/GoldRule.astro';
import TopStripe from '../components/TopStripe.astro';
import Button from '../components/Button.astro';
import { t } from '../i18n/utils';

const locale = 'et' as const;

const pageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "EventVenue",
    "@id": "https://laitsecastle.ee/#venue",
    "name": "Laitse loss",
    "url": "https://laitsecastle.ee/peod",
    "telephone": "+37253300206",
    "email": "info@laitsecastle.ee",
    "image": "https://laitsecastle.ee/signed-images/loss-oosel.webp",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Lossi tee 9",
      "addressLocality": "Laitse",
      "postalCode": "76302",
      "addressRegion": "Harjumaa",
      "addressCountry": "EE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 59.1966,
      "longitude": 24.3846
    },
    "maximumAttendeeCapacity": 100
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://laitsecastle.ee/peod#pulmad",
    "name": "Pulmad Laitse lossis",
    "description": "Ajaloolise lossi romantiline õhkkond loob unustamatu tausta teie kõige olulisemale päevale.",
    "serviceType": "Wedding Venue",
    "provider": { "@id": "https://laitsecastle.ee/#organization" },
    "areaServed": { "@type": "Country", "name": "Estonia" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://laitsecastle.ee/peod#seminarid",
    "name": "Seminarid ja konverentsid Laitse lossis",
    "description": "Inspireeriv ajalooline keskkond seminaridele, konverentsidele ja meeskonnaüritustele.",
    "serviceType": "Conference and Seminar Venue",
    "provider": { "@id": "https://laitsecastle.ee/#organization" }
  }
];
---

<BaseLayout
  title={t(locale, 'events.meta.title')}
  description={t(locale, 'events.meta.description')}
  locale="et"
  ogImage="/fotopank/LaitseCastle_night_Toomas-Tuul.webp"
  pageSchema={pageSchema}
>
  <!-- Hero -->
  <section class="relative min-h-[85vh] md:min-h-[88vh] flex items-center justify-center overflow-hidden">
    <TopStripe />
    <img
      src="/fotopank/LaitseLoss_Aiast_Toomas-Tuul.webp"
      alt={t(locale, 'events.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-10 text-center px-6 py-24 max-w-2xl mx-auto">
      <h1 class="font-display text-hero text-warm-white mb-8 text-overlay hero-enter" style="--delay: 0ms">
        {t(locale, 'events.hero.heading')}
      </h1>
      <div class="hero-enter mt-2" style="--delay: 150ms">
        <Button variant="filled" href="#kontakt" label={t(locale, 'cta.contact')} />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TEIE SÜNDMUS LOSSIS — service types
       ═══════════════════════════════════════════ -->
  <section class="section-fade-from-dark pt-12 md:pt-16 pb-20 md:pb-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12" data-animate>
        <h2 class="font-display text-section text-warm-dark mb-5">{t(locale, 'events.services.heading')}</h2>
        <Flourish type="vintage" size="sm" fill="burgundy" />
        <p class="font-subtitle text-[clamp(24px,3vw,34px)] italic text-stone mt-6 max-w-2xl mx-auto">{t(locale, 'events.services.subtitle')}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
        <!-- Sünnipäevad ja tähtpäevad -->
        <div class="service-card group relative overflow-hidden rounded block" data-animate data-animate-delay="100">
          <img
            src="/fotopank/LaitseCastle_night_Toomas-Tuul.webp"
            alt={t(locale, 'events.services.card1.imageAlt')}
            class="w-full h-[340px] md:h-[400px] object-cover group-hover:scale-[1.03] transition-transform duration-700"
          />
          <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-overlay">
            <div class="w-10 group-hover:w-12 h-[2px] bg-gold-gradient-h mb-4 transition-all duration-500"></div>
            <h3 class="font-display text-[clamp(22px,2.5vw,28px)] text-warm-white mb-2 leading-tight">{t(locale, 'events.services.card1.title')}</h3>
            <p class="font-body text-body text-warm-white/80 leading-relaxed">{t(locale, 'events.services.card1.desc')}</p>
          </div>
        </div>

        <!-- Pulmad -->
        <div class="service-card group relative overflow-hidden rounded block" data-animate data-animate-delay="250">
          <img
            src="/fotopank/LaitseCastle_Toomas-Tuul.webp"
            alt={t(locale, 'events.services.card2.imageAlt')}
            class="w-full h-[340px] md:h-[400px] object-cover group-hover:scale-[1.03] transition-transform duration-700"
          />
          <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-overlay">
            <div class="w-10 group-hover:w-12 h-[2px] bg-gold-gradient-h mb-4 transition-all duration-500"></div>
            <h3 class="font-display text-[clamp(22px,2.5vw,28px)] text-warm-white mb-2 leading-tight">{t(locale, 'events.services.card2.title')}</h3>
            <p class="font-body text-body text-warm-white/80 leading-relaxed">{t(locale, 'events.services.card2.desc')}</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MEIE RUUMID
       ═══════════════════════════════════════════ -->
  <section class="bg-warm-light px-6 py-20 md:py-28">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16" data-animate>
        <p class="font-ui text-[15px] font-bold uppercase tracking-[0.2em] text-gold mb-4">{t(locale, 'events.rooms.eyebrow')}</p>
        <h2 class="font-display text-section text-warm-dark mb-5">{t(locale, 'events.rooms.heading')}</h2>
        <Flourish type="vintage" size="sm" fill="burgundy" />
      </div>

      <!-- Klaverisalong -->
      <div class="grid md:grid-cols-2 gap-8 lg:gap-16 items-center mb-20 md:mb-28" data-animate>
        <div class="group overflow-hidden rounded">
          <img
            src="/fotopank/LaitseLoss_Salong.webp"
            alt={t(locale, 'events.rooms.klaverisalong.imageAlt')}
            class="w-full h-80 lg:h-96 object-cover group-hover:scale-[1.03] transition-transform duration-700"
            loading="lazy"
          />
        </div>
        <div>
          <h3 class="font-subtitle text-[clamp(24px,2.5vw,32px)] text-warm-dark mb-2">{t(locale, 'events.rooms.klaverisalong.name')}</h3>
          <p class="font-ui text-[15px] font-bold uppercase tracking-wider text-gold mb-4">{t(locale, 'events.rooms.klaverisalong.floor')}</p>
          <GoldRule width="50px" />
          <p class="font-body text-body-lg text-stone mt-5 leading-relaxed">
            {t(locale, 'events.rooms.klaverisalong.desc')}
          </p>

          <table class="w-full font-ui text-[15px] text-warm-dark mt-6">
            <thead>
              <tr class="border-b border-stone/20">
                <th class="text-left py-2 font-normal text-stone uppercase text-label-sm tracking-wider">{t(locale, 'events.table.layout')}</th>
                <th class="text-right py-2 font-normal text-stone uppercase text-label-sm tracking-wider">{t(locale, 'events.table.capacity')}</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-stone/10">
                <td class="py-2.5">{t(locale, 'events.table.uLaud')}</td>
                <td class="text-right py-2.5">24</td>
              </tr>
              <tr class="border-b border-stone/10">
                <td class="py-2.5">{t(locale, 'events.table.koosolek')}</td>
                <td class="text-right py-2.5">32</td>
              </tr>
              <tr class="border-b border-stone/10">
                <td class="py-2.5">{t(locale, 'events.table.klassiruum')}</td>
                <td class="text-right py-2.5">40</td>
              </tr>
              <tr>
                <td class="py-2.5">{t(locale, 'events.table.teater')}</td>
                <td class="text-right py-2.5">64</td>
              </tr>
            </tbody>
          </table>

          <a href="/saalide-plaanid" class="inline-flex items-center gap-2 mt-6 font-ui text-[15px] uppercase tracking-wider text-burgundy border-b border-burgundy/40 pb-1 hover:border-burgundy transition-colors">
            Vaata saalide plaane <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Peasaal (reversed) -->
      <div class="grid md:grid-cols-2 gap-8 lg:gap-16 items-center mb-20 md:mb-28" data-animate>
        <div class="md:order-2 group overflow-hidden rounded">
          <img
            src="/fotopank/LaitseLoss_Soogisaal1a.webp"
            alt={t(locale, 'events.rooms.peasaal.imageAlt')}
            class="w-full h-80 lg:h-96 object-cover group-hover:scale-[1.03] transition-transform duration-700"
            loading="lazy"
          />
        </div>
        <div class="md:order-1">
          <h3 class="font-subtitle text-[clamp(24px,2.5vw,32px)] text-warm-dark mb-2">{t(locale, 'events.rooms.peasaal.name')}</h3>
          <p class="font-ui text-[15px] font-bold uppercase tracking-wider text-gold mb-4">{t(locale, 'events.rooms.peasaal.floor')}</p>
          <GoldRule width="50px" />
          <p class="font-body text-body-lg text-stone mt-5 leading-relaxed">
            {t(locale, 'events.rooms.peasaal.desc')}
          </p>

          <table class="w-full font-ui text-[15px] text-warm-dark mt-6">
            <thead>
              <tr class="border-b border-stone/20">
                <th class="text-left py-2 font-normal text-stone uppercase text-label-sm tracking-wider">{t(locale, 'events.table.layout')}</th>
                <th class="text-right py-2 font-normal text-stone uppercase text-label-sm tracking-wider">{t(locale, 'events.table.capacity')}</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-stone/10">
                <td class="py-2.5">{t(locale, 'events.table.pikkLaud')}</td>
                <td class="text-right py-2.5">40</td>
              </tr>
              <tr>
                <td class="py-2.5">{t(locale, 'events.table.bankett')}</td>
                <td class="text-right py-2.5">60</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Suur peosaal -->
      <div class="grid md:grid-cols-2 gap-8 lg:gap-16 items-center mb-20 md:mb-28" data-animate>
        <div class="group overflow-hidden rounded">
          <img
            src="/fotopank/LaitseLoss_Peosaal1.webp"
            alt={t(locale, 'events.rooms.suursaal.imageAlt')}
            class="w-full h-80 lg:h-96 object-cover group-hover:scale-[1.03] transition-transform duration-700"
            loading="lazy"
          />
        </div>
        <div>
          <h3 class="font-subtitle text-[clamp(24px,2.5vw,32px)] text-warm-dark mb-2">{t(locale, 'events.rooms.suursaal.name')}</h3>
          <p class="font-ui text-[15px] font-bold uppercase tracking-wider text-gold mb-4">{t(locale, 'events.rooms.suursaal.floor')}</p>
          <GoldRule width="50px" />
          <p class="font-body text-body-lg text-stone mt-5 leading-relaxed">
            {t(locale, 'events.rooms.suursaal.desc')}
          </p>

          <table class="w-full font-ui text-[15px] text-warm-dark mt-6">
            <thead>
              <tr class="border-b border-stone/20">
                <th class="text-left py-2 font-normal text-stone uppercase text-label-sm tracking-wider">{t(locale, 'events.table.layout')}</th>
                <th class="text-right py-2 font-normal text-stone uppercase text-label-sm tracking-wider">{t(locale, 'events.table.capacity')}</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-stone/10">
                <td class="py-2.5">{t(locale, 'events.table.bankett')}</td>
                <td class="text-right py-2.5">90</td>
              </tr>
              <tr class="border-b border-stone/10">
                <td class="py-2.5">{t(locale, 'events.table.2pikkalauda')}</td>
                <td class="text-right py-2.5">100</td>
              </tr>
              <tr>
                <td class="py-2.5">{t(locale, 'events.table.teater')}</td>
                <td class="text-right py-2.5">100</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Terrass ja aed (reversed) -->
      <div class="grid md:grid-cols-2 gap-8 lg:gap-16 items-center" data-animate>
        <div class="md:order-2 group overflow-hidden rounded">
          <img
            src="/fotopank/LaitseLoss_terrass_Toomas-Tuul.webp"
            alt={t(locale, 'events.rooms.terrass.imageAlt')}
            class="w-full h-80 lg:h-96 object-cover object-bottom group-hover:scale-[1.03] transition-transform duration-700"
            loading="lazy"
          />
        </div>
        <div class="md:order-1">
          <h3 class="font-subtitle text-[clamp(24px,2.5vw,32px)] text-warm-dark mb-2">{t(locale, 'events.rooms.terrass.name')}</h3>
          <p class="font-ui text-[15px] font-bold uppercase tracking-wider text-gold mb-4">{t(locale, 'events.rooms.terrass.floor')}</p>
          <GoldRule width="50px" />
          <p class="font-body text-body-lg text-stone mt-5 leading-relaxed">
            {t(locale, 'events.rooms.terrass.desc')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MIDA PAKUME
       ═══════════════════════════════════════════ -->
  <section class="px-6 py-20 md:py-28">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12" data-animate>
        <Flourish type="vintage" size="sm" fill="burgundy" />
        <h2 class="font-display text-section text-warm-dark mt-6 mb-4">{t(locale, 'events.offer.heading')}</h2>
        <p class="font-subtitle text-[clamp(24px,3vw,34px)] italic text-stone max-w-2xl mx-auto">
          {t(locale, 'events.offer.subtitle')}
        </p>
      </div>

      <ul class="space-y-6" data-animate>
        <li class="flex items-start gap-4">
          <span class="text-gold text-xl mt-0.5" aria-hidden="true">&#9830;</span>
          <div>
            <p class="font-body text-body-lg text-warm-dark font-bold">{t(locale, 'events.offer.item1.title')}</p>
            <p class="font-body text-body-lg text-stone">{t(locale, 'events.offer.item1.desc')}</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <span class="text-gold text-xl mt-0.5" aria-hidden="true">&#9830;</span>
          <div>
            <p class="font-body text-body-lg text-warm-dark font-bold">{t(locale, 'events.offer.item2.title')}</p>
            <p class="font-body text-body-lg text-stone">{t(locale, 'events.offer.item2.desc')}</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <span class="text-gold text-xl mt-0.5" aria-hidden="true">&#9830;</span>
          <div>
            <p class="font-body text-body-lg text-warm-dark font-bold">{t(locale, 'events.offer.item3.title')}</p>
            <p class="font-body text-body-lg text-stone">{t(locale, 'events.offer.item3.desc')}</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <span class="text-gold text-xl mt-0.5" aria-hidden="true">&#9830;</span>
          <div>
            <p class="font-body text-body-lg text-warm-dark font-bold">{t(locale, 'events.offer.item4.title')}</p>
            <p class="font-body text-body-lg text-stone">{t(locale, 'events.offer.item4.desc')}</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA
       ═══════════════════════════════════════════ -->
  <section id="kontakt" class="px-6 py-20 md:py-28 bg-warm-light">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">{t(locale, 'cta.bookEvent')}</h2>
      <p class="font-body text-body-lg text-stone mb-8 leading-relaxed">
        {t(locale, 'cta.bookEventDesc')}
      </p>

      <div class="mb-10">
        <a href="tel:+37253300206" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors inline-flex items-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.tel')}</span> +372 5330 0206
        </a>
        <a href="mailto:info@laitsecastle.ee" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors flex items-center justify-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.email')}</span> info@laitsecastle.ee
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
