---
import BaseLayout from '../layouts/BaseLayout.astro';
import Flourish from '../components/Flourish.astro';
import GoldRule from '../components/GoldRule.astro';
import BurgundyRule from '../components/BurgundyRule.astro';
import TopStripe from '../components/TopStripe.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Sündmused — Laitse Loss"
  description="Peod, seminarid ja konverentsid ajaloolises Laitse Lossis. Elegantne keskkond Harjumaal, vaid 30 min Tallinnast."
  ogImage="/images/Pulmad.jpg"
>

  <!-- ═══════════════════════════════════════════
       1. HERO
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <TopStripe />
    <img
      src="/images/01-pulm.webp"
      alt="Pidulikult kaunistatud saal Laitse Lossis"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-warm-dark/60"></div>
    <div class="relative z-10 text-center px-6 py-24 max-w-3xl mx-auto">
      <h1 class="font-display text-hero text-warm-white mb-6">
        Sündmused Laitse Lossis
      </h1>
      <p class="font-subtitle text-subtitle italic text-warm-white/80 mb-10">
        Peod, tähtpäevad, seminarid ja konverentsid ajaloolises lossis
      </p>
      <Flourish type="vintage" size="md" fill="gold" />
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
        <a
          href="#peod"
          class="font-ui uppercase tracking-wider text-[15px] inline-block transition-colors duration-300 no-underline px-10 py-4 border border-warm-white/60 text-warm-white hover:bg-warm-white/10"
        >
          Peod &darr;
        </a>
        <a
          href="#seminarid"
          class="font-ui uppercase tracking-wider text-[15px] inline-block transition-colors duration-300 no-underline px-10 py-4 border border-warm-white/60 text-warm-white hover:bg-warm-white/10"
        >
          Seminarid &darr;
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       2. PEOD JA TÄHTPÄEVAD
       ═══════════════════════════════════════════ -->
  <section id="peod" class="scroll-mt-20 px-6 py-20 md:py-28">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="font-ui text-label-sm uppercase tracking-wider text-gold mb-3">Peod</p>
        <h2 class="font-display text-section text-warm-dark mb-4">Peod ja tähtpäevad</h2>
        <BurgundyRule width="60px" />
        <p class="font-body text-body-lg text-stone mt-6 max-w-2xl mx-auto">
          Ajaloolise lossi romantiline õhkkond loob unustamatu tausta igale pidustusele.
          Elegantne saal, kaunis aed ja eriline atmosfäär — kõik, et teie sündmus oleks
          just selline, nagu ette kujutasite.
        </p>
      </div>

      <!-- Celebration types — compact 3-col -->
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8 mb-16">
        <!-- Pulmad -->
        <div class="group bg-white rounded shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
          <div class="overflow-hidden">
            <img
              src="/images/Pulmad.jpg"
              alt="Pulmapaar Laitse Lossi ees"
              class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5 lg:p-6">
            <h3 class="font-subtitle text-[clamp(20px,1.8vw,26px)] text-warm-dark mb-2">Pulmad</h3>
            <GoldRule width="36px" />
            <p class="font-body text-body text-stone mt-3 leading-relaxed">
              Romantiline keskkond teie kõige olulisemale päevale. Tseremoonia lossi aias, pidu ajaloolises saalis.
            </p>
          </div>
        </div>

        <!-- Sünnipäevad -->
        <div class="group bg-white rounded shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
          <div class="overflow-hidden">
            <img
              src="/images/Peolaud-Kuldses-saalis.jpg"
              alt="Pidulikult kaetud laud kuldses saalis"
              class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5 lg:p-6">
            <h3 class="font-subtitle text-[clamp(20px,1.8vw,26px)] text-warm-dark mb-2">Sünnipäevad ja tähtpäevad</h3>
            <GoldRule width="36px" />
            <p class="font-body text-body text-stone mt-3 leading-relaxed">
              Intiimsetest koosviibimistest suuremate pidustusteni — lossi miljöö teeb iga tähtpäeva meeldejäävaks.
            </p>
          </div>
        </div>

        <!-- Firmapeod -->
        <div class="group bg-white rounded shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
          <div class="overflow-hidden">
            <img
              src="/images/main_gastro.jpg"
              alt="Elegantne lauakatmine firmapeo jaoks"
              class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5 lg:p-6">
            <h3 class="font-subtitle text-[clamp(20px,1.8vw,26px)] text-warm-dark mb-2">Firmapeod ja galaõhtud</h3>
            <GoldRule width="36px" />
            <p class="font-body text-body text-stone mt-3 leading-relaxed">
              Muljetavaldav keskkond ettevõtte üritustele. Lossi ajaloolised saalid annavad sündmusele erilise kaalu.
            </p>
          </div>
        </div>
      </div>

      <!-- Rooms overview — compact grid -->
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8 mb-14">
        <div class="text-center">
          <img
            src="/images/Suur_saal_galerii.jpg"
            alt="Suur saal Laitse Lossis"
            class="w-full h-44 object-cover rounded mb-4"
            loading="lazy"
          />
          <h4 class="font-subtitle text-[clamp(18px,1.6vw,22px)] text-warm-dark mb-1">Suur saal</h4>
          <p class="font-ui text-label-sm uppercase tracking-wider text-gold mb-2">110 m² · kuni 150 külalist</p>
          <p class="font-body text-body text-stone">Lossi suurim ruum — kõrgete lagedega, sobib suursugusteks banketipidudeks ja kontsertideks.</p>
        </div>
        <div class="text-center">
          <img
            src="/images/Peolaud-Kuldses-saalis.jpg"
            alt="Salong Laitse Lossis"
            class="w-full h-44 object-cover rounded mb-4"
            loading="lazy"
          />
          <h4 class="font-subtitle text-[clamp(18px,1.6vw,22px)] text-warm-dark mb-1">Salong</h4>
          <p class="font-ui text-label-sm uppercase tracking-wider text-gold mb-2">56 m² · kuni 64 külalist</p>
          <p class="font-body text-body text-stone">Intiimne ja soe ruum, mis sobib väiksematele tähistamistele ja pere koosviibimisteks.</p>
        </div>
        <div class="text-center">
          <img
            src="/images/Terrass.jpg"
            alt="Laitse Lossi terrass ja aed"
            class="w-full h-44 object-cover rounded mb-4"
            loading="lazy"
          />
          <h4 class="font-subtitle text-[clamp(18px,1.6vw,22px)] text-warm-dark mb-1">Terrass ja aed</h4>
          <p class="font-ui text-label-sm uppercase tracking-wider text-gold mb-2">Välialad</p>
          <p class="font-body text-body text-stone">Suveperioodil ideaalne koht tseremooniateks, kokteilideks ja vastuvõttudeks värskes õhus.</p>
        </div>
      </div>

      <!-- Mida pakume — compact bullets -->
      <div class="max-w-2xl mx-auto">
        <h3 class="font-subtitle text-[clamp(20px,1.8vw,26px)] text-warm-dark text-center mb-6">Mida pakume</h3>
        <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3">
          <p class="flex items-start gap-3 font-body text-body text-stone">
            <span class="text-gold mt-0.5" aria-hidden="true">&#9830;</span>
            Abi toitlustuslahenduse leidmisel
          </p>
          <p class="flex items-start gap-3 font-body text-body text-stone">
            <span class="text-gold mt-0.5" aria-hidden="true">&#9830;</span>
            Kaunistused ja dekoreerimine
          </p>
          <p class="flex items-start gap-3 font-body text-body text-stone">
            <span class="text-gold mt-0.5" aria-hidden="true">&#9830;</span>
            Muusika ja meelelahutus
          </p>
          <p class="flex items-start gap-3 font-body text-body text-stone">
            <span class="text-gold mt-0.5" aria-hidden="true">&#9830;</span>
            Suvel aed ja terrass
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       3. VISUAL DIVIDER
       ═══════════════════════════════════════════ -->
  <div class="py-10 flex flex-col items-center gap-4 bg-warm-dark/[0.03]">
    <GoldRule width="200px" />
    <Flourish type="vintage" size="sm" fill="gold" />
  </div>

  <!-- ═══════════════════════════════════════════
       4. SEMINARID JA KONVERENTSID
       ═══════════════════════════════════════════ -->
  <section id="seminarid" class="scroll-mt-20 px-6 py-20 md:py-28 bg-warm-light">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="font-ui text-label-sm uppercase tracking-wider text-gold mb-3">Seminarid</p>
        <h2 class="font-display text-section text-warm-dark mb-4">Seminarid ja konverentsid</h2>
        <BurgundyRule width="60px" />
        <p class="font-body text-body-lg text-stone mt-6 max-w-2xl mx-auto">
          Laitse lossi ajalooline miljöö loob atmosfääri,
          kus ideed sünnivad kergemini ja kohtumised jäävad meelde.
        </p>
      </div>

      <!-- Rooms with capacity tables -->
      <div class="grid md:grid-cols-2 gap-10 lg:gap-14 mb-14">

        <!-- Salong -->
        <div>
          <div class="overflow-hidden rounded-sm mb-5">
            <img
              src="/images/Salong_.jpg"
              alt="Salong — seminariruum Laitse lossis"
              class="w-full h-56 md:h-64 object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="font-subtitle text-[clamp(22px,2vw,28px)] text-warm-dark mb-1">Salong</h3>
          <p class="font-ui text-label-sm uppercase tracking-wider text-stone mb-4">I korrus &middot; 56 m²</p>
          <p class="font-body text-body text-stone mb-5">
            Klassikalise interjööriga ruum lossi esimesel korrusel. Loomulik valgus ja hubane õhkkond sobivad ideaalselt seminari või töötoa läbiviimiseks.
          </p>
          <table class="w-full font-ui text-[14px] text-warm-dark">
            <thead>
              <tr class="border-b border-stone/20">
                <th class="text-left py-2 font-normal text-stone uppercase text-label-sm tracking-wider">Paigutus</th>
                <th class="text-right py-2 font-normal text-stone uppercase text-label-sm tracking-wider">Mahutavus</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-stone/10">
                <td class="py-2">U-laud</td>
                <td class="text-right py-2">24</td>
              </tr>
              <tr class="border-b border-stone/10">
                <td class="py-2">Diplomaadistiilis</td>
                <td class="text-right py-2">32</td>
              </tr>
              <tr class="border-b border-stone/10">
                <td class="py-2">Klassiruum</td>
                <td class="text-right py-2">40</td>
              </tr>
              <tr>
                <td class="py-2">Teatristiilis</td>
                <td class="text-right py-2">64</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Suur saal -->
        <div>
          <div class="overflow-hidden rounded-sm mb-5">
            <img
              src="/images/Suur_saal_tuhi.jpg"
              alt="Suur saal — lossi suurim konverentsiruum"
              class="w-full h-56 md:h-64 object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="font-subtitle text-[clamp(22px,2vw,28px)] text-warm-dark mb-1">Suur saal</h3>
          <p class="font-ui text-label-sm uppercase tracking-wider text-stone mb-4">Soklikorrus &middot; 110 m²</p>
          <p class="font-body text-body text-stone mb-5">
            Lossi suurim ruum — avar ja kõrgete lagedega. Sobib suurematele konverentsidele, kus vajate mahtu ja paindlikkust.
          </p>
          <table class="w-full font-ui text-[14px] text-warm-dark">
            <thead>
              <tr class="border-b border-stone/20">
                <th class="text-left py-2 font-normal text-stone uppercase text-label-sm tracking-wider">Paigutus</th>
                <th class="text-right py-2 font-normal text-stone uppercase text-label-sm tracking-wider">Mahutavus</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-stone/10">
                <td class="py-2">Teatristiilis</td>
                <td class="text-right py-2">150</td>
              </tr>
              <tr>
                <td class="py-2">Banketi ümarlauad</td>
                <td class="text-right py-2">100</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Equipment — compact inline -->
      <div class="max-w-2xl mx-auto text-center mb-10">
        <h3 class="font-subtitle text-[clamp(20px,1.8vw,26px)] text-warm-dark mb-4">Tehnika ja varustus</h3>
        <p class="font-body text-body text-stone">
          Projektor ja ekraan &middot; WiFi &middot; Tahvel / flipchart
        </p>
        <p class="font-ui text-[13px] text-stone mt-3 italic">
          Täpsem varustus kokkuleppel — küsige meilt
        </p>
      </div>

      <!-- Location -->
      <div class="max-w-2xl mx-auto text-center">
        <GoldRule width="60px" />
        <p class="font-subtitle text-subtitle text-burgundy mt-6 mb-2">
          ~30 minutit Tallinna kesklinnast
        </p>
        <p class="font-body text-body text-stone">
          Tasuta parkimine lossi territooriumil &middot; Lossi tee 9, Laitse, Harjumaa
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       5. CONTACT CTA
       ═══════════════════════════════════════════ -->
  <section class="px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center">
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">Võtke ühendust</h2>
      <p class="font-body text-body-lg text-stone mb-8">
        Iga sündmus on erinev. Rääkige meile oma soovidest
        ja leiame koos parima lahenduse.
      </p>

      <div class="space-y-2 mb-10">
        <p class="font-body text-body-lg text-warm-dark">
          <span class="text-stone">Tel:</span>
          <a href="tel:+37258356509" class="text-warm-dark hover:text-burgundy transition-colors">+372 58 356 509</a>
        </p>
        <p class="font-body text-body-lg text-warm-dark">
          <span class="text-stone">E-post:</span>
          <a href="mailto:info@laitseloss.ee" class="text-warm-dark hover:text-burgundy transition-colors">info@laitseloss.ee</a>
        </p>
      </div>

      <Button variant="filled" href="mailto:info@laitseloss.ee" label="Küsi pakkumist" />
    </div>
  </section>

</BaseLayout>

<style>
  /* Smooth scroll for anchor links */
  html {
    scroll-behavior: smooth;
  }

</style>
