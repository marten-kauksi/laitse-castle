---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Flourish from '../../components/Flourish.astro';
import TopStripe from '../../components/TopStripe.astro';
import Button from '../../components/Button.astro';
import { t } from '../../i18n/utils';

const locale = 'en' as const;

// item3 (Entertainment) is expanded into its own section with sub-pages below
const items = ['item1', 'item2', 'item4', 'item5'];
---

<BaseLayout
  title={t(locale, 'addons.meta.title')}
  description={t(locale, 'addons.meta.description')}
  locale="en"
  ogImage="/fotopank/LaitseLoss_terrass_Toomas-Tuul.webp"
>
  <!-- Hero -->
  <section class="relative min-h-[70vh] md:min-h-[78vh] flex items-center justify-center overflow-hidden">
    <TopStripe />
    <img
      src="/fotopank/LaitseLoss_terrass_Toomas-Tuul.webp"
      alt={t(locale, 'addons.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover object-bottom"
    />
    <div class="relative z-10 text-center px-6 py-24 max-w-2xl mx-auto">
      <h1 class="font-display text-hero text-warm-white mb-6 text-overlay hero-enter" style="--delay: 0ms">
        {t(locale, 'addons.hero.heading')}
      </h1>
      <p class="font-subtitle font-bold italic text-[clamp(24px,3vw,34px)] text-warm-white mb-8 hero-enter" style="--delay: 150ms; text-shadow: 0 2px 14px rgba(0,0,0,0.98), 0 0 6px rgba(0,0,0,0.9), 0 1px 3px rgba(0,0,0,0.98)">
        {t(locale, 'addons.hero.subtitle')}
      </p>
      <div class="hero-enter mt-6" style="--delay: 300ms">
        <Button variant="filled" href="#contact" label={t(locale, 'cta.contact')} />
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section-fade-from-dark px-6 py-20 md:py-24">
    <div class="max-w-3xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-display text-section text-warm-dark mt-6 mb-5">{t(locale, 'addons.intro.heading')}</h2>
      <p class="font-body text-body-lg text-stone leading-relaxed">{t(locale, 'addons.intro.body')}</p>
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-warm-light px-6 py-20 md:py-28">
    <div class="max-w-5xl mx-auto">
      <div class="grid sm:grid-cols-2 gap-8 md:gap-10">
        {items.map((key, i) => (
          <div class="flex items-start gap-4" data-animate data-animate-delay={(i + 1) * 80}>
            <span class="text-gold text-xl mt-1" aria-hidden="true">&#9830;</span>
            <div>
              <h3 class="font-subtitle text-[clamp(20px,2.2vw,24px)] text-warm-dark mb-2">{t(locale, `addons.${key}.title`)}</h3>
              <p class="font-body text-body text-stone leading-relaxed">{t(locale, `addons.${key}.desc`)}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Entertainment — sub-pages -->
  <section class="px-6 py-20 md:py-28">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14" data-animate>
        <Flourish type="vintage" size="sm" fill="burgundy" />
        <h2 class="font-display text-section text-warm-dark mt-6">Entertainment</h2>
      </div>

      <!-- Murder mystery -->
      <a href="/en/additional-services/murder-mystery" class="group block border-t border-stone/15 pt-10 mb-10" data-animate>
        <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-center">
          <div class="overflow-hidden rounded">
            <img src="/fotopank/LaitseLoss_mysteerium1a_Katrin-Luts.webp" alt="Murder mystery at Laitse Castle" class="w-full h-64 md:h-80 object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
          </div>
          <div>
            <h3 class="font-subtitle text-[clamp(26px,3.2vw,36px)] text-burgundy group-hover:text-burgundy-hover transition-colors mb-4">Murder mystery</h3>
            <p class="font-body text-body-lg text-warm-dark mb-3">A murder mystery dinner includes:</p>
            <ul class="space-y-2 mb-4">
              {[
                'a three-course dinner in the castle halls',
                'a glass of sparkling wine on arrival',
                'a glass of wine',
                'the mystery hosted by an experienced game master',
                'prop rental on request',
              ].map((item) => (
                <li class="flex items-start gap-3 font-body text-body text-warm-dark">
                  <span class="text-gold mt-1" aria-hidden="true">&#9830;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p class="font-body text-body text-stone">We run murder mysteries in five languages: Estonian, English, Spanish, Finnish and Russian. The mystery together with the dinner lasts about 2.5 hours.</p>
            <span class="inline-block mt-5 font-ui text-[15px] uppercase tracking-wider text-burgundy border-b border-burgundy/40 pb-1 group-hover:border-burgundy transition-colors">Read more →</span>
          </div>
        </div>
      </a>

      <!-- Chocolate truffle workshop -->
      <a href="/en/additional-services/chocolate-workshop" class="group block border-t border-stone/15 pt-10" data-animate>
        <div class="grid md:grid-cols-2 gap-6 md:gap-10 items-center">
          <div class="overflow-hidden rounded">
            <img src="/fotopank/LaitseLoss_tryhvlid2_Krista-Ruben.webp" alt="Chocolate truffles" class="w-full h-64 md:h-72 object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
          </div>
          <div>
            <h3 class="font-subtitle text-[clamp(26px,3.2vw,36px)] text-burgundy group-hover:text-burgundy-hover transition-colors mb-4">Chocolate truffle workshop</h3>
            <p class="font-body text-body-lg text-warm-dark">Making truffles is a lovely undertaking that can be enjoyed alone or together with others. It is nice to do with colleagues or simply with friends, as this activity can also be excellent teamwork.</p>
            <span class="inline-block mt-5 font-ui text-[15px] uppercase tracking-wider text-burgundy border-b border-burgundy/40 pb-1 group-hover:border-burgundy transition-colors">Read more →</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="bg-warm-light px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">{t(locale, 'cta.bookEvent')}</h2>
      <p class="font-body text-body-lg text-stone mb-8 leading-relaxed">{t(locale, 'cta.bookEventDesc')}</p>
      <div class="mb-10">
        <a href="tel:+37253300206" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors inline-flex items-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.tel')}</span> +372 5330 0206
        </a>
        <a href="mailto:info@laitsecastle.ee" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors flex items-center justify-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.email')}</span> info@laitsecastle.ee
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
