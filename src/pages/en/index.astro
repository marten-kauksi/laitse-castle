---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Flourish from '../../components/Flourish.astro';
import GoldRule from '../../components/GoldRule.astro';
import TopStripe from '../../components/TopStripe.astro';
import Button from '../../components/Button.astro';
import { t } from '../../i18n/utils';

const locale = 'en' as const;

const eventVenueSchema = {
  "@context": "https://schema.org",
  "@type": ["EventVenue", "LocalBusiness"],
  "@id": "https://laitsecastle.ee/#venue",
  "name": "Laitse Castle",
  "alternateName": "Laitse loss",
  "description": "Historic neo-Gothic castle in Harju County — ideal for weddings, celebrations, seminars and conferences. ~40 minutes from Tallinn.",
  "url": "https://laitsecastle.ee/en",
  "telephone": "+37253300206",
  "email": "info@laitsecastle.ee",
  "image": [
    "https://laitsecastle.ee/signed-images/drooni-vaade.webp",
    "https://laitsecastle.ee/signed-images/loss-oosel.webp",
    "https://laitsecastle.ee/images/saal.jpg"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lossi tee 9",
    "addressLocality": "Laitse",
    "postalCode": "76302",
    "addressRegion": "Harjumaa",
    "addressCountry": "EE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 59.1966,
    "longitude": 24.3846
  },
  "hasMap": "https://maps.google.com/?q=59.1966,24.3846",
  "maximumAttendeeCapacity": 100,
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Free parking", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "WiFi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Projector and screen", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Terrace", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Garden", "value": true }
  ],
  "containsPlace": [
    {
      "@type": "MeetingRoom",
      "@id": "https://laitsecastle.ee/#peasaal",
      "name": "Main Hall",
      "maximumAttendeeCapacity": 100
    },
    {
      "@type": "MeetingRoom",
      "@id": "https://laitsecastle.ee/#klaverisalong",
      "name": "Piano Lounge",
      "maximumAttendeeCapacity": 64
    },
    {
      "@type": "MeetingRoom",
      "@id": "https://laitsecastle.ee/#suur-saal",
      "name": "Grand Hall"
    }
  ],
  "parentOrganization": {
    "@id": "https://laitsecastle.ee/#organization"
  }
};
---

<BaseLayout
  locale="en"
  title={t(locale, 'home.meta.title')}
  description={t(locale, 'home.meta.description')}
  pageSchema={eventVenueSchema}
>

  <!-- ═══════════════════════════════════════════
       1. HERO
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-start overflow-hidden">
    <TopStripe />

    <img
      src="/signed-images/drooni-vaade.webp"
      alt={t(locale, 'home.hero.imageAlt')}
      class="absolute inset-0 w-full h-full object-cover object-[center_25%]"
      fetchpriority="high"
      decoding="async"
    />

    <div class="relative z-10 flex flex-col items-center text-center gap-5 max-w-2xl px-6 pt-28 md:pt-32">
      <h1 class="hero-enter font-display text-[clamp(44px,7vw,80px)] text-warm-white leading-[1.05]" style="--delay: 100ms; text-shadow: 0 2px 24px rgba(0,0,0,0.95), 0 1px 4px rgba(0,0,0,0.9)">{t(locale, 'home.hero.title')}</h1>

      <p class="hero-enter font-subtitle italic text-subtitle text-warm-white" style="--delay: 300ms; text-shadow: 0 2px 16px rgba(0,0,0,0.95), 0 1px 3px rgba(0,0,0,0.95)">
        {t(locale, 'home.hero.subtitle')}
      </p>

      <div class="hero-enter mt-6" style="--delay: 450ms">
        <Button variant="filled" href="#contact" label={t(locale, 'cta.contact')} />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       1b. SUMMER TERRACE — announcement band
       ═══════════════════════════════════════════ -->
  <section class="bg-warm-white px-6 py-8 md:py-10">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-subtitle font-semibold text-[clamp(22px,2.6vw,32px)] text-burgundy leading-snug">{t(locale, 'home.terrace.line1')}</p>
      <p class="font-body text-body-lg text-warm-dark mt-2">{t(locale, 'home.terrace.line2')}</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       2. SERVICES — Two equal cards
       ═══════════════════════════════════════════ -->
  <section class="section-fade-from-dark pt-12 md:pt-16 pb-20 md:pb-28 px-6">
    <div class="max-w-2xl mx-auto text-center mb-12" data-animate>
      <h2 class="font-display text-section text-warm-dark mb-5">{t(locale, 'home.services.heading')}</h2>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <p class="font-body text-body-lg text-stone mt-6 leading-relaxed">{t(locale, 'home.services.subtitle')}</p>
    </div>
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8">

        <!-- Birthdays, celebrations and weddings — large featured card -->
        <a href="/en/events-and-seminars" class="service-card md:col-span-7 group relative overflow-hidden rounded block" data-animate data-animate-delay="100">
          <img
            src="/fotopank/terrass1.webp"
            alt={t(locale, 'home.services.card1.imageAlt')}
            class="w-full h-[400px] md:h-[520px] object-cover group-hover:scale-[1.03] transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10 text-overlay">
            <div class="w-12 group-hover:w-14 h-[2px] bg-gold-gradient-h mb-5 transition-all duration-500"></div>
            <h2 class="font-display text-[clamp(26px,3vw,36px)] text-warm-white leading-tight">
              {t(locale, 'home.services.card1.title')}
            </h2>
          </div>
        </a>

        <!-- Right column: Corporate events and seminars -->
        <div class="md:col-span-5 flex flex-col gap-6 md:gap-8">

          <!-- Corporate events and seminars card -->
          <a href="/en/seminars" class="service-card group relative overflow-hidden rounded flex-1 block" data-animate data-animate-delay="250">
            <img
              src="/images/seminarid-firmayritused.webp"
              alt={t(locale, 'home.services.card2.imageAlt')}
              class="w-full h-[240px] md:h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
              loading="lazy"
            />
              <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-overlay">
              <div class="w-10 group-hover:w-12 h-[2px] bg-gold-gradient-h mb-4 transition-all duration-500"></div>
              <h2 class="font-display text-[clamp(22px,2.5vw,28px)] text-warm-white leading-tight">
                {t(locale, 'home.services.card2.title')}
              </h2>
            </div>
          </a>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       4. CASTLE STORY — Full-bleed immersive
       ═══════════════════════════════════════════ -->
  <section class="section-into-dark relative min-h-[50vh] md:min-h-[60vh] flex items-center overflow-hidden py-12 md:py-20">
    <img
      src="/signed-images/lossi-torn-ajalugu.webp"
      alt={t(locale, 'home.story.imageAlt')}
      class="absolute inset-0 w-full h-[120%] object-cover will-change-transform"
      loading="lazy"
      data-parallax
    />

    <div class="relative z-10 max-w-2xl mx-auto px-6 py-20 md:py-28 text-center text-overlay" data-animate>
      <p class="font-ui text-label-sm uppercase tracking-[0.2em] text-gold-light mb-5">{t(locale, 'home.story.eyebrow')}</p>
      <h2 class="font-display text-[clamp(28px,4vw,44px)] text-warm-white mb-8 leading-tight">
        {t(locale, 'home.story.heading')}
      </h2>
      <p class="font-body text-body-lg text-warm-white/90 mb-6 leading-relaxed">
        {t(locale, 'home.story.p1')}
      </p>
      <p class="font-body text-body-lg text-warm-white/80 mb-10 leading-relaxed">
        {t(locale, 'home.story.p2')}
      </p>
      <a href="/en/history" class="font-ui text-[15px] uppercase tracking-wider text-warm-white border-b border-warm-white/40 pb-1 hover:border-warm-white transition-colors">
        {t(locale, 'home.story.cta')}
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       5. CTA
       ═══════════════════════════════════════════ -->
  <section id="contact" class="section-fade-from-dark py-20 md:py-28 px-6">
    <div class="max-w-2xl mx-auto text-center" data-animate>
      <Flourish type="vintage" size="sm" fill="burgundy" />
      <h2 class="font-subtitle text-section text-burgundy mt-6 mb-4">{t(locale, 'cta.bookEvent')}</h2>
      <p class="font-body text-body-lg text-stone mb-8 leading-relaxed">
        {t(locale, 'cta.bookEventDesc')}
      </p>

      <div class="mb-10">
        <a href="tel:+37253300206" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors inline-flex items-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.tel')}</span> +372 5330 0206
        </a>
        <a href="mailto:info@laitsecastle.ee" class="font-body text-body-lg text-warm-dark hover:text-burgundy transition-colors flex items-center justify-center gap-2 min-h-[44px]">
          <span class="text-stone">{t(locale, 'contact.email')}</span> info@laitsecastle.ee
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  section:first-of-type :global(a.border-burgundy) {
    border-color: rgba(250, 247, 242, 0.5);
    color: #FAF7F2;
  }
  section:first-of-type :global(a.border-burgundy:hover) {
    background-color: rgba(250, 247, 242, 0.12);
    border-color: #FAF7F2;
    color: #FAF7F2;
  }
</style>
